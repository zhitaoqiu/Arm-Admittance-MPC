<mujoco model="two_link_arm">
  <compiler angle="radian"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint type="hinge" axis="0 0 1" damping="0.05"/>
    <geom type="capsule" size="0.035" density="800" rgba="0.3 0.5 0.9 1"/>
    <motor ctrllimited="true" ctrlrange="-20 20"/>
  </default>

  <worldbody>
    <light name="top_light" pos="0 0 2"/>

    <camera name="fixed" pos="0 -1.8 1.2" xyaxes="1 0 0 0 0.6 0.8"/>

    <geom name="floor" type="plane" size="1.5 1.5 0.01" rgba="0.9 0.9 0.9 1"/>

    <site name="target_site" type="sphere" pos="0.55 0.25 0.05" size="0.04" rgba="0 1 0 1"/>

    <site name="admittance_ref_site" type="sphere" pos="0.55 0.25 0.09" size="0.03" rgba="1 1 0 1"/>

    <body name="base" pos="0 0 0.05">
      <geom name="base_geom" type="sphere" size="0.06" rgba="0.1 0.1 0.1 1"/>

      <body name="link1" pos="0 0 0">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14" limited="true"/>
        <geom name="link1_geom" fromto="0 0 0 0.5 0 0"/>

        <body name="link2" pos="0.5 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-3.14 3.14" limited="true"/>
          <geom name="link2_geom" fromto="0 0 0 0.4 0 0"/>

          <site name="ee_site" pos="0.4 0 0" size="0.035" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="joint1" gear="1"/>
    <motor name="motor2" joint="joint2" gear="1"/>
  </actuator>
</mujoco>